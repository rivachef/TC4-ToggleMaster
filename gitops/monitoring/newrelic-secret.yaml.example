# New Relic License Key Secret
# Copy this file to newrelic-secret.yaml and fill in your license key.
# DO NOT commit the actual secret to git.
#
# To get your license key:
# 1. Go to https://one.newrelic.com
# 2. Click on your profile (bottom-left) -> API Keys
# 3. Copy the INGEST - LICENSE key
#
# Apply manually: kubectl apply -f gitops/monitoring/newrelic-secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: newrelic-license-key
  namespace: monitoring
type: Opaque
stringData:
  license-key: "<YOUR_NEW_RELIC_LICENSE_KEY>"
